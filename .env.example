# API Configuration (Binance Futures)
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here
# If fapi.binance.com is blocked or slow, you can try:
# BINANCE_BASE_URL=https://fapi.binance.co

# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
# If Telegram is blocked in your region (read ECONNRESET), you can use a custom API proxy URL, for example:
# TELEGRAM_BASE_URL=https://api.telegram.org


# Bot Settings
LOG_LEVEL=info
SCAN_INTERVAL_SECONDS=60
UNIVERSE_REFRESH_MINUTES=60
TOP_N_SYMBOLS=30

# Signal Settings
MIN_SIGNAL_SCORE=70
COOLDOWN_MINUTES=15
MAX_ALERTS_PER_SYMBOL_PER_DAY=12
MAX_ALERTS_GLOBAL_PER_DAY=120
